{
  "manifest_version": 3,
  "name": "X Redirect",
  "description": "Redirects X (Formerlly Twitter) to Nitter or other website you want",
  "homepage_url": "https://github.com/agostaxyz/xredirect",
  "version": "1.1",
  "icons": {
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_icon": "assets/icon-32.png",
    "default_title": "X Redirect Settings",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["browser-polyfill.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://www.x.com/*", "*://mobile.x.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ]
}
